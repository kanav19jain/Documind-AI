PORT=5000
NODE_ENV=development

# MongoDB Atlas connection URI
# Get from: https://cloud.mongodb.com/ > Connect > Drivers > Node.js
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT secret for token signing (use any random string)
JWT_SECRET=your_jwt_secret_here

# Gemini Embeddings API key (generates 3072-dim vectors)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq LLM API key (ultra-fast inference)
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Pinecone Vector Database (cloud vector storage)
# Get from: https://app.pinecone.io/
# Create an index with dimension=3072 and metric=cosine
USE_PINECONE=true
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_pinecone_index_name_here

# Frontend URL for CORS (set this in production)
# FRONTEND_URL=https://your-app.vercel.app
